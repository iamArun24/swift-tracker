# Server Configuration (Render provides PORT automatically)
PORT=8080

# Database (For Render, PostgreSQL addon will provide RENDER_DB_URL)
# If using PostgreSQL addon, this will be auto-set by Render
# If using SQLite (not recommended for production):
DB_PATH=./swifttrack.db

# JWT Secret (CHANGE THIS IN PRODUCTION!)
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=swifttrack_jwt_secret_key_2024_change_this_in_production_very_long_secure_string

# CORS Allowed Origin - Your Frontend URL
ALLOWED_ORIGIN=https://swift-tracker.netlify.app
